# Appwrite API Key (for server-side operations)
APPWRITE_API_KEY=your_api_key_here

# Appwrite Configuration
EXPO_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
EXPO_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here

# These will be auto-generated by the setup script
EXPO_PUBLIC_APPWRITE_DATABASE_ID=your_database_id_here
EXPO_PUBLIC_APPWRITE_SPEECHES_COLLECTION_ID=your_speeches_collection_id_here
EXPO_PUBLIC_APPWRITE_CHANNELS_COLLECTION_ID=your_channels_collection_id_here

# Search Configuration
# Set to "true" to disable live search suggestions while typing (history will still show)
EXPO_PUBLIC_DISABLE_SEARCH_SUGGESTIONS=true
